# Pramana Configuration
# Copy to .env and fill in values

# LLM Provider (OpenAI-compatible)
PRAMANA_LLM_BASE_URL=https://api.ai.it.ufl.edu
PRAMANA_LLM_API_KEY=your-api-key-here
PRAMANA_LLM_MODEL=gpt-4o
PRAMANA_LLM_TEMPERATURE=0.1
PRAMANA_LLM_MAX_TOKENS=4096

# Data directories
PRAMANA_DATA_DIR=data
PRAMANA_DB_PATH=data/pramana.db
PRAMANA_CHROMA_PATH=data/chroma
PRAMANA_PDF_DIR=data/pdfs

# Paper source API keys (optional, increases rate limits)
PRAMANA_SEMANTIC_SCHOLAR_API_KEY=
PRAMANA_PUBMED_API_KEY=

# API server
PRAMANA_API_HOST=0.0.0.0
PRAMANA_API_PORT=8000
